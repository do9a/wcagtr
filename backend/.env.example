NODE_ENV=development
PORT=3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=wcagtr
DB_USER=wcagtr_user
DB_PASSWORD=your_secure_password

# JWT Secrets
JWT_SECRET=your_jwt_secret_min_32_chars
JWT_EXPIRES_IN=365d
TOKEN_SIGNING_KEY=your_hmac_signing_key_for_patches
WIDGET_JWT_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----
WIDGET_JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nYOUR_PUBLIC_KEY\n-----END PUBLIC KEY-----
WIDGET_JWT_EXPIRES_IN=365d
WIDGET_API_BASE=https://api.wcagtr.app/api/v1

# AI Provider
AI_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key

# Payment (initial integration)
PAYMENT_PROVIDER=mock
PAYMENT_WEBHOOK_SECRET=your_payment_webhook_secret_min_32_chars
PAYMENT_CHECKOUT_BASE_URL=http://localhost:3000
PAYMENT_AUTO_APPROVE_MOCK=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=http://localhost:3000/customer-panel/#/billing?payment=success&session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=http://localhost:3000/customer-panel/#/billing?payment=cancelled
STRIPE_WEBHOOK_TOLERANCE_SECONDS=300
IYZICO_API_BASE_URL=https://sandbox-api.iyzipay.com
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_CALLBACK_URL=http://localhost:3000/api/v1/payments/webhook/iyzico
IYZICO_DEFAULT_GSM=+905350000000
IYZICO_DEFAULT_IDENTITY_NUMBER=11111111111
IYZICO_DEFAULT_ADDRESS=Maslak Mah. Teknoloji Cad. No:1
IYZICO_DEFAULT_CITY=Istanbul
IYZICO_DEFAULT_COUNTRY=Turkey
IYZICO_DEFAULT_ZIP_CODE=34000
IYZICO_DEFAULT_BUYER_IP=85.34.78.112

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
